# ─────────────────────────────────────────────────────────────
# VedaAI — environment variable master list
#
# Local dev: copy this file to .env at repo root (or per-app .env files).
# Production: set each var in the corresponding Railway service's
# Variables tab. Use Railway's ${{ Service.VAR }} references for
# cross-service URLs (Mongo, Redis, internal Railway domains).
# ─────────────────────────────────────────────────────────────

# ─── apps/web (Next.js) ──────────────────────────────────────
# Browser-exposed vars MUST be prefixed NEXT_PUBLIC_ and require rebuild on change.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NODE_ENV=development

# ─── apps/api (Express + Socket.IO) ──────────────────────────
PORT=4000
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000
GEMINI_API_KEY=AIza-paste-your-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── apps/worker (BullMQ consumer) ───────────────────────────
# Reuses MONGODB_URI / REDIS_URL / GEMINI_API_KEY / GEMINI_MODEL above.
# Set them again in the Railway worker service.

# ─────────────────────────────────────────────────────────────
# Railway production reference values (paste in Railway dashboard, NOT here):
#
# apps/web service:
#   NEXT_PUBLIC_API_URL = https://${{ api.RAILWAY_PUBLIC_DOMAIN }}
#   NEXT_PUBLIC_WS_URL  = https://${{ api.RAILWAY_PUBLIC_DOMAIN }}
#   NODE_ENV            = production
#
# apps/api service:
#   PORT                = ${{ PORT }}                  (Railway injects)
#   MONGODB_URI         = ${{ MongoDB.MONGO_URL }}     (Railway plugin ref)
#   REDIS_URL           = ${{ Redis.REDIS_URL }}       (Railway plugin ref)
#   CORS_ORIGINS        = https://${{ web.RAILWAY_PUBLIC_DOMAIN }}
#   GEMINI_API_KEY      = <paste from Google AI Studio>
#   GEMINI_MODEL        = gemini-2.0-flash
#   NODE_ENV            = production
#
# apps/worker service:
#   MONGODB_URI         = ${{ MongoDB.MONGO_URL }}
#   REDIS_URL           = ${{ Redis.REDIS_URL }}
#   GEMINI_API_KEY      = <same as api>
#   GEMINI_MODEL        = gemini-2.0-flash
#   NODE_ENV            = production
# ─────────────────────────────────────────────────────────────
